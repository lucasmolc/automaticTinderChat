# ============================================
# CONFIGURAÇÕES DO AUTOMATIC TINDER CHAT
# ============================================
# Copie este arquivo para .env e configure suas variáveis.
# Nada aqui é obrigatório para o app iniciar: sem chave de IA ele sobe a
# interface normalmente, e sem DATABASE_URL ele usa SQLite local.

# ============================================
# OPENAI API
# ============================================
OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_MODEL=gpt-4o
# Modelos disponíveis: gpt-4o, gpt-4o-mini, gpt-4-turbo

# ============================================
# DEEPSEEK API (opcional)
# ============================================
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# CLAUDE / ANTHROPIC API (opcional)
# ============================================
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ============================================
# BANCO DE DADOS
# ============================================
# DATABASE_URL é a forma preferida (SQLAlchemy). Se ficar vazio, o app usa
# automaticamente um arquivo SQLite em data/automatic_tinder_chat.db (zero config).
#
# Exemplos:
#   SQLite (padrão):  sqlite:///./data/automatic_tinder_chat.db
#   PostgreSQL:       postgresql+psycopg2://usuario:senha@localhost:5432/tinderchat
#   SQL Server:       mssql+pyodbc://usuario:senha@host/banco?driver=ODBC+Driver+17+for+SQL+Server
#
# Deixe comentado para usar SQLite:
# DATABASE_URL=

# Alternativa legada para SQL Server via connection string ODBC (usada só se
# DATABASE_URL estiver vazio). Para autenticação Windows use Trusted_Connection=yes.
# SQL_SERVER_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=AutomaticTinderChat;UID=usuario;PWD=senha

# ============================================
# CONFIGURAÇÕES DO BROWSER
# ============================================
# Caminho para o perfil do navegador (para manter sessão logada). Opcional.
CHROME_USER_DATA_DIR=
CHROME_PROFILE=Default
BROWSER_HEADLESS=false

# ============================================
# CONFIGURAÇÕES DA AUTOMAÇÃO
# ============================================
# Intervalo entre ações (em segundos) — evita detecção
ACTION_DELAY_MIN=2
ACTION_DELAY_MAX=5

# Máximo de mensagens processadas por execução
MAX_MESSAGES_PER_RUN=20

# Dias sem interação para considerar conversa fria
DAYS_WITHOUT_INTERACTION=7

# ============================================
# FILTROS
# ============================================
# Ignorar matches do DoubleDate (matches em dupla)
IGNORE_DOUBLEDATE=true

# ============================================
# CONFIGURAÇÕES DE LOG
# ============================================
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=10
